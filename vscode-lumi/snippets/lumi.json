{
  "Print text": {
    "prefix": "print",
    "body": [
      "print \"${1:Hello from Lumi!}\""
    ],
    "description": "Print a value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:name} == ${2:\"value\"} then",
      "    ${3:print \"Matched\"}",
      "else if ${4:name} == ${5:\"other\"} then",
      "    ${6:print \"Matched something else\"}",
      "else",
      "    ${7:print \"Not matched\"}",
      "end"
    ],
    "description": "Lumi if/else-if/else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1}-t-${3:60}",
      "    ${4:print ${1:i}}",
      "    ${1:i}++",
      "end"
    ],
    "description": "Loop through a numeric range using an incremented variable"
  },
  "Convert to integer": {
    "prefix": "int",
    "body": [
      "${1:number} = (int) ${2:text}"
    ],
    "description": "Convert a numeric value or string into an integer"
  },
  "Integer-only text box": {
    "prefix": "intsonly",
    "body": [
      "${1:textBox}.setIntsOnly(${2|true,false|})"
    ],
    "description": "Allow only whole-number input in a text box"
  },
  "Create text area": {
    "prefix": "textarea",
    "body": [
      "textA ${1:notes} = \"${2:Write here}\""
    ],
    "description": "Create a multiline Lumi text area"
  },
  "Scan text component": {
    "prefix": "scan",
    "body": [
      "${1:textComponent}.scan(${2:value})"
    ],
    "description": "Copy text-box or text-area content into a variable"
  },
  "Create frame": {
    "prefix": "frame",
    "body": [
      "frame.create(\"${1:Hello}\")",
      "frame.size=${2:700},${3:900}",
      "frame.icon(\"${4:icon.png}\")",
      "$0",
      "frame.visible(true)"
    ],
    "description": "Create and show a Lumi frame"
  },
  "Import constructor": {
    "prefix": "import",
    "body": [
      "import ${1:Hello}"
    ],
    "description": "Run a registered Lumi constructor"
  },
  "Create label": {
    "prefix": "label",
    "body": [
      "Label.create(${1:\"Hello\"}).varname(${2:helloLabel})"
    ],
    "description": "Create a named Lumi label from text or a variable"
  },
  "Set component font": {
    "prefix": "setfont",
    "body": [
      "${1:componentName}.setFont(\"${2:Arial}\", ${3|BOLD,PLAIN,ITALIC,UNDERLINED,INDENTED,LARGE|}, ${4:18})"
    ],
    "description": "Set a Lumi component's font family, style, and size"
  },
  "Create file": {
    "prefix": "file",
    "body": [
      "file.create(\"${1:Hello.txt}\",\"${2:Hello}\")"
    ],
    "description": "Create a file relative to the Lumi program"
  },
  "Listen for key": {
    "prefix": "key",
    "body": [
      "key.listen(${1:L}) {",
      "    ${2:print \"Key pressed\"}",
      "}"
    ],
    "description": "Run code when a key is pressed"
  },
  "Create panel": {
    "prefix": "panel",
    "body": [
      "Panel ${1:p} = (${2:helloLabel,helloButton})"
    ],
    "description": "Create a panel containing named components"
  },
  "Read input": {
    "prefix": "input",
    "body": [
      "input(\"${1:Enter a value: }\" (${2:value}))"
    ],
    "description": "Prompt for input and store it in a variable"
  },
  "Close frame": {
    "prefix": "close",
    "body": [
      "frame.close()"
    ],
    "description": "Close the current Lumi frame"
  },
  "Delete component": {
    "prefix": "delete",
    "body": [
      "${1:componentName}.delete"
    ],
    "description": "Remove a named GUI component"
  },
  "Send notification": {
    "prefix": "notify",
    "body": [
      "notify(\"${1:Hello}\",\"${2:Hello Ray}\")"
    ],
    "description": "Send a desktop notification"
  }
}
